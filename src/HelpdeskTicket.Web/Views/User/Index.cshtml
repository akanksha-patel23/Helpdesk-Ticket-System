@model HelpdeskTicket.Web.ViewModels.User.UserListViewModel
@{
    ViewData["Title"] = "User Management";
    ViewData["ActivePage"] = "Users";

    string RoleBadge(int roleId) => roleId switch
    {
        1 => "bg-danger",
        2 => "bg-primary",
        _ => "bg-secondary"
    };
}

<!-- Page header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h5 class="fw-bold mb-0">User Management</h5>
        <p class="text-muted small mb-0" id="totalLabel">
            @Model.Users.Count total user@(Model.Users.Count != 1 ? "s" : "")
        </p>
    </div>
    <a asp-controller="User" asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-person-plus me-1"></i>New User
    </a>
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <div class="row g-2 align-items-end">

            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Search</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" id="userSearch" class="form-control"
                           placeholder="Search by name, email or role…" />
                </div>
            </div>

            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Filter</label>
                <select id="quickFilter" class="form-select form-select-sm">
                    <option value="all">All Users</option>
                    <option value="latest10">Latest 10</option>
                    <option value="active">Active Only</option>
                    <option value="inactive">Inactive Only</option>
                    <option value="admin">Admins</option>
                    <option value="developer">Developers</option>
                    <option value="enduser">End Users</option>
                </select>
            </div>

            <!-- Date range — From -->
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Joined From</label>
                <input type="date" id="dateFrom" class="form-control form-control-sm" />
            </div>

            <!-- Date range — To -->
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Joined To</label>
                <input type="date" id="dateTo" class="form-control form-control-sm" />
            </div>

            <div class="col-md-1">
                <button type="button" id="clearFilters"
                        class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-x-circle me-1"></i>Clear
                </button>
            </div>
            <div class="col-md-1">
                <button type="button" id="applyFilters" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-funnel me-1"></i>Apply
                </button>
            </div>

            @* <div class="col-md-2 text-end">
                <span id="resultCount" class="text-muted small"></span>
            </div> *@

        </div>
    </div>
</div>
<div id="dateRangeError" class="alert alert-danger d-none py-1 px-2 mb-1 small" role="alert">
    <i class="bi bi-exclamation-triangle me-1"></i>
    "Joined From" date must be less than "Joined To" date.
</div>
<!-- User grid -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Users.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people fs-1 opacity-25 d-block mb-2"></i>
                No users found.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="userTable">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Joined</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="userTableBody">
                        @{
                            var sortedUsers = Model.Users
                            .OrderByDescending(u => u.CreatedDateTime)
                            .ToList();
                            var rank = 0;
                        }
                        @foreach (var user in sortedUsers)
                        {
                            rank++;
                            <tr class="user-row"
                                data-rank="@rank"
                                data-name="@user.FullName.ToLower()"
                                data-email="@user.Email.ToLower()"
                                data-role="@user.RoleName.ToLower()"
                                data-roleid="@user.RoleId"
                                data-active="@user.IsActive.ToString().ToLower()"
                                data-joined="@user.CreatedDateTime.ToString("yyyy-MM-dd")">

                                @* <td class="ps-3 text-muted small">@user.Id</td> *@
                                <td class="ps-3 text-muted small">@rank</td>
                                <td class="fw-semibold small">@user.FullName</td>
                                <td class="small text-muted">@user.Email</td>
                                <td>
                                    <span class="badge @RoleBadge(user.RoleId) rounded-pill">
                                        @user.RoleName
                                    </span>
                                </td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark rounded-pill border">Inactive</span>
                                    }
                                </td>
                                <td class="small text-muted">
                                    @user.CreatedDateTime.ToString("dd MMM yyyy")
                                </td>
                                <td class="text-center">
                                    <a asp-controller="User" asp-action="Edit"
                                       asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-primary py-0 px-2"
                                       title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    @* Send reset link form/button *@
                                    @* <form asp-controller="User" asp-action="SendResetLink" method="post" class="d-inline ms-1" onsubmit="return confirm('Send password reset link to @user.Email ?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary py-0 px-2" title="Send reset link">
                                            <i class="bi bi-envelope-plus"></i>
                                        </button>
                                    </form> *@
                                    <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2"
                                            title="Send reset link"
                                            data-bs-toggle="modal"
                                            data-bs-target="#resetLinkModal"
                                            data-user-id="@user.Id"
                                            data-user-email="@user.Email">
                                        <i class="bi bi-envelope-plus"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @* for sending reset password link from admin page*@
                <div class="modal fade" id="resetLinkModal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h6 class="modal-title">Send Password Reset Link</h6>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                Send password reset link to <strong id="resetLinkEmail"></strong>?
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                <form id="resetLinkForm" asp-controller="User" asp-action="SendResetLink" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" id="resetLinkUserId" />
                                    <button type="submit" class="btn btn-primary btn-sm">Send Link</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="noResults" class="text-center py-4 text-muted d-none">
                <i class="bi bi-search opacity-25 fs-2 d-block mb-2"></i>
                No users match your filters.
            </div>

            <!-- Pagination -->
            <div class="d-flex align-items-center justify-content-between px-3 py-3 border-top flex-wrap gap-2"
                 id="paginationContainer">

                <div class="text-muted small" id="pageInfo"></div>

                <nav>
                    <ul class="pagination pagination-sm mb-0" id="pageNumbers"></ul>
                </nav>

                <div class="d-flex align-items-center gap-2">
                    <label class="text-muted small">Rows</label>
                    <select id="pageSizeSelect" class="form-select form-select-sm"
                            style="width:75px;">
                        <option value="10" selected>10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                </div>

            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
                const searchInput    = document.getElementById('userSearch');
        const quickFilter    = document.getElementById('quickFilter');
        const dateFrom       = document.getElementById('dateFrom');
        const dateTo         = document.getElementById('dateTo');
        const clearBtn       = document.getElementById('clearFilters');
        const resultCount    = document.getElementById('resultCount');
        const noResults      = document.getElementById('noResults');
        const pageInfo       = document.getElementById('pageInfo');
        const pageNumbers    = document.getElementById('pageNumbers');
        const pageSizeSelect = document.getElementById('pageSizeSelect');
        const paginationContainer = document.getElementById('paginationContainer');

        const allRows = Array.from(document.querySelectorAll('.user-row'));

        let currentPage  = 1;
        let pageSize     = 10;
        let filteredRows = [];

        //filter logic
        function getFilteredRows() {
                if (dateFrom.value && dateTo.value && dateFrom.value > dateTo.value) {
            return []; // or return allRows, your choice — alert already shown
        }
            const q      = searchInput.value.toLowerCase().trim();
            const filter = quickFilter.value;
            const from   = dateFrom.value ? new Date(dateFrom.value) : null;
            const to     = dateTo.value   ? new Date(dateTo.value)   : null;
            if (to) to.setHours(23, 59, 59, 999); // include full end day

            return allRows.filter(row => {
                const name   = row.dataset.name;
                const email  = row.dataset.email;
                const role   = row.dataset.role;
                const roleId = parseInt(row.dataset.roleid);
                const active = row.dataset.active === 'true';
                const rank   = parseInt(row.dataset.rank);
                const joined = new Date(row.dataset.joined);

                // Search
                const searchMatch = !q ||
                    name.includes(q) || email.includes(q) || role.includes(q);

                // Quick filter
                let filterMatch = true;
                switch (filter) {
                    case 'latest10':  filterMatch = rank <= 10;   break;
                    case 'active':    filterMatch = active;       break;
                    case 'inactive':  filterMatch = !active;      break;
                    case 'admin':     filterMatch = roleId === 1; break;
                    case 'developer': filterMatch = roleId === 2; break;
                    case 'enduser':   filterMatch = roleId === 3; break;
                }

                // Date range
                const dateMatch =
                    (!from || joined >= from) &&
                    (!to   || joined <= to);

                return searchMatch && filterMatch && dateMatch;
            });
        }

        function renderPage() {
            filteredRows = getFilteredRows();
            const total      = filteredRows.length;
            const totalPages = Math.max(1, Math.ceil(total / pageSize));

            if (currentPage > totalPages) currentPage = totalPages;

            const start = (currentPage - 1) * pageSize;
            const end   = Math.min(start + pageSize, total);

        // show/hide rows
            allRows.forEach(r => r.style.display = 'none');
            filteredRows.slice(start, end).forEach(r => r.style.display = '');

        //no results
            if (noResults) noResults.classList.toggle('d-none', total > 0);

        //result count label
            // resultCount.textContent = total === allRows.length
            //     ? `${total} user${total !== 1 ? 's' : ''}`
            //     : `${total} of ${allRows.length} user${allRows.length !== 1 ? 's' : ''}`;
                if (resultCount) resultCount.textContent = total === allRows.length
        ? `${total} user${total !== 1 ? 's' : ''}`
        : `${total} of ${allRows.length} user${allRows.length !== 1 ? 's' : ''}`;

        //page info
            if (pageInfo) {
                pageInfo.textContent = total === 0
                    ? ''
                    : `Showing ${start + 1}–${end} of ${total}`;
            }

        //hide paginataion if only 1 page
            if (paginationContainer)
                paginationContainer.style.display = totalPages <= 1 ? 'none' : '';

        //build page number buttons
            if (pageNumbers) {
                pageNumbers.innerHTML = '';

                const prev = document.createElement('li');
                prev.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
                prev.innerHTML = `<a class="page-link" href="#"><i class="bi bi-chevron-left"></i></a>`;
                prev.addEventListener('click', e => {
                    e.preventDefault();
                    if (currentPage > 1) { currentPage--; renderPage(); }
                });
                pageNumbers.appendChild(prev);

        //page nos: 1 to 5
                const startPage = Math.max(1, Math.min(currentPage - 2, totalPages - 4));
                const endPage   = Math.min(totalPages, startPage + 4);

                if (startPage > 1) {
                    pageNumbers.appendChild(makePageBtn(1));
                    if (startPage > 2) pageNumbers.appendChild(makeEllipsis());
                }
                for (let p = startPage; p <= endPage; p++)
                    pageNumbers.appendChild(makePageBtn(p));
                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) pageNumbers.appendChild(makeEllipsis());
                    pageNumbers.appendChild(makePageBtn(totalPages));
                }

        //next
                const next = document.createElement('li');
                next.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
                next.innerHTML = `<a class="page-link" href="#"><i class="bi bi-chevron-right"></i></a>`;
                next.addEventListener('click', e => {
                    e.preventDefault();
                    if (currentPage < totalPages) { currentPage++; renderPage(); }
                });
                pageNumbers.appendChild(next);
            }
        }

        function makePageBtn(p) {
            const li = document.createElement('li');
            li.className = `page-item ${p === currentPage ? 'active' : ''}`;
            li.innerHTML = `<a class="page-link" href="#">${p}</a>`;
            li.addEventListener('click', e => {
                e.preventDefault(); currentPage = p; renderPage();
            });
            return li;
        }

        function makeEllipsis() {
            const li = document.createElement('li');
            li.className = 'page-item disabled';
            li.innerHTML = '<span class="page-link">…</span>';
            return li;
        }

        //event listeners
        // searchInput?.addEventListener('input',  () => { currentPage = 1; renderPage(); });
        // quickFilter?.addEventListener('change', () => { currentPage = 1; renderPage(); });
        // dateFrom?.addEventListener('change',    () => { currentPage = 1; renderPage(); });
        // dateTo?.addEventListener('change',      () => { currentPage = 1; renderPage(); });
        //         dateFrom?.addEventListener('change', () => {
        //     if (!validateDateRange()) { renderPage(); return; }
        //     currentPage = 1; renderPage();
        // });
        // dateTo?.addEventListener('change', () => {
        //     if (!validateDateRange()) { renderPage(); return; }
        //     currentPage = 1; renderPage();
        // });
                document.getElementById('applyFilters')?.addEventListener('click', () => {
            if (!validateDateRange()) return;
            currentPage = 1;
            renderPage();
        });

                const dateRangeError = document.getElementById('dateRangeError');
        function validateDateRange() {
            if (dateFrom.value && dateTo.value && dateFrom.value > dateTo.value) {
                dateRangeError.classList.remove('d-none');
                return false;
            }
            dateRangeError.classList.add('d-none');
            return true;
        }

        pageSizeSelect?.addEventListener('change', () => {
            pageSize = parseInt(pageSizeSelect.value);
            currentPage = 1;
            renderPage();
        });

        clearBtn?.addEventListener('click', () => {
            searchInput.value = '';
            quickFilter.value = 'all';
            dateFrom.value    = '';
            dateTo.value      = '';
            dateRangeError.classList.add('d-none'); 
            currentPage       = 1;
            renderPage();
        });

        renderPage();

                document.getElementById('applyFilters')?.addEventListener('click', () => {
            if (!validateDateRange()) return;
            currentPage = 1;
            renderPage();
        });
        //admin -> send reset link alert box
                document.getElementById('resetLinkModal')?.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('resetLinkEmail').textContent = btn.getAttribute('data-user-email');
            document.getElementById('resetLinkUserId').value = btn.getAttribute('data-user-id');
        });
    </script>
}