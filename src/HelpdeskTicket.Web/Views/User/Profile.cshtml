@model HelpdeskTicket.Web.ViewModels.User.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    ViewData["ActivePage"] = "Profile";

    string RoleBadge(string role) => role switch
    {
        "Admin" => "bg-danger",
        "Developer" => "bg-primary",
        _ => "bg-secondary"
    };
}

<div class="row justify-content-center">
    <div class="col-lg-6">

        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="rounded-3 p-2 bg-primary bg-opacity-10 text-primary fs-4">
                <i class="bi bi-person-circle"></i>
            </div>
            <div>
                <h5 class="fw-bold mb-0">My Profile</h5>
                <p class="text-muted small mb-0">Your account information.</p>
            </div>
        </div>

        <!-- Profile info card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">

                <!-- Avatar + name -->
                <div class="d-flex align-items-center gap-3 mb-4 pb-3 border-bottom">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center
                                justify-content-center fw-bold fs-3 flex-shrink-0"
                         style="width:64px;height:64px;">
                        @Model.FullName.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <div class="fw-bold fs-5">@Model.FullName</div>
                        <div class="text-muted small">@Model.Email</div>
                        @* <span class="badge @RoleBadge(Model.RoleName) rounded-pill mt-1">
                            @Model.RoleName
                        </span> *@
                    </div>
                </div>

                <!-- Details -->
                @* <dl class="row mb-0 small">
                    <dt class="col-4 text-muted fw-normal">User ID</dt>
                    <dd class="col-8">#@Model.UserId</dd>

                    <dt class="col-4 text-muted fw-normal">Full Name</dt>
                    <dd class="col-8 fw-semibold">@Model.FullName</dd>

                    <dt class="col-4 text-muted fw-normal">Email</dt>
                    <dd class="col-8">@Model.Email</dd>

                    <dt class="col-4 text-muted fw-normal">Role</dt>
                    <dd class="col-8">@Model.RoleName</dd>

                    <dt class="col-4 text-muted fw-normal">Member Since</dt>
                    <dd class="col-8">@Model.CreatedDateTime.ToString("dd MMM yyyy")</dd>
                </dl> *@
                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="UserId" />

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Role</label><br />
                        <span class="badge @RoleBadge(Model.RoleName)">
                            @Model.RoleName
                        </span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Member Since</label>
                        <div class="text-muted">
                            @Model.CreatedDateTime.ToString("dd MMM yyyy")
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-check2 me-1"></i>
                            Save Changes
                        </button>

                        @* <a asp-controller="Dashboard"
                           asp-action="Index"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-left me-1"></i>
                            Back
                        </a> *@
                    </div>
                </form>
            </div>
        </div>

        <!-- Info notice -->
        @* <div class="alert alert-info border-0 shadow-sm small">
            <i class="bi bi-info-circle me-2"></i>
            To update your name or email, please contact an Admin. Role changes are managed by the system administrator.
        </div> *@

        <a asp-controller="Dashboard" asp-action="Index"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>
</div>