@model HelpdeskTicket.Web.ViewModels.Ticket.TicketDetailViewModel

@{
    //ViewData["Title"] = $"Update Ticket #{Model.Ticket.Id}";
    int displayNumber;
    if (!int.TryParse(Context.Request.Query["displayNumber"], out displayNumber))
    {
        displayNumber = Model.Ticket.Id;
    }
    ViewData["Title"] = $"Update Ticket #{displayNumber}";

    ViewData["ActivePage"] = "Tickets";

    var roleId = HelpdeskTicket.Web.Helpers.SessionHelper.GetRoleId(Context.Session);
    bool isAdmin = roleId == 1;
    bool isDeveloper = roleId == 2;
}

<div class="d-flex align-items-center gap-3 mb-4">

    <a asp-action="Details"
       asp-route-id="@Model.Ticket.Id"
       asp-route-displayNumber="@displayNumber"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>

    <div>
        <h5 class="fw-bold mb-0">
            <!--Update Ticket #@Model.Ticket.Id-->
            Update Ticket #@displayNumber
        </h5>
        <p class="text-muted small mb-0">
            Modify status, priority or assignment
        </p>
    </div>

</div>

<div class="card border-0 shadow-sm">

    <div class="card-header bg-white">
        <h6 class="fw-semibold mb-0">
            Ticket Settings
        </h6>
    </div>

    <div class="card-body">

        <form asp-action="Update" method="post">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   name="ticketId"
                   value="@Model.Ticket.Id" />
            <input type="hidden" name="displayNumber" value="@displayNumber" />

            <div class="mb-3">
                <label class="form-label">Status</label>

                <select name="statusId"
                        class="form-select">

                    @foreach (var s in Model.Statuses)
                    {
                        @if (isDeveloper && (s.Text == "Open" || s.Text == "Closed"))
                        {
                            continue;
                        }
                        <option value="@s.Value"
                                selected="@(Model.Ticket.StatusId.ToString() == s.Value ? "selected" : null)">
                            @s.Text
                        </option>
                    }

                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Priority</label>

                <select name="priorityId"
                        class="form-select">

                    @foreach (var p in Model.Priorities)
                    {
                        <option value="@p.Value"
                                selected="@(Model.Ticket.PriorityId.ToString() == p.Value ? "selected" : null)">
                            @p.Text
                        </option>
                    }

                </select>
            </div>

            @if (isAdmin)
            {
                <div class="mb-4">

                    <label class="form-label">
                        Assign To
                    </label>

                    <select name="assignedToId"
                            class="form-select">

                        @foreach (var dev in Model.Developers)
                        {
                            <option value="@dev.Value"
                                    selected="@(Model.Ticket.AssignedToId?.ToString() == dev.Value ? "selected" : null)">
                                @dev.Text
                            </option>
                        }

                    </select>

                </div>
            }

            <div class="d-flex gap-2">

                <a asp-action="Details"
                   asp-route-id="@Model.Ticket.Id"
                   asp-route-displayNumber="@displayNumber"
                   class="btn btn-outline-secondary flex-fill">
                    Cancel
                </a>

                <button type="submit"
                        class="btn btn-warning flex-fill">
                    <i class="bi bi-check2 me-1"></i>
                    Save Changes
                </button>

            </div>

        </form>

    </div>

</div>