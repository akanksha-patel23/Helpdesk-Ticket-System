@model HelpdeskTicket.Web.ViewModels.Auth.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — Helpdesk</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            background: linear-gradient(135deg,#1e293b 0%,#0f172a 100%);
            min-height: 100vh;
        }

        .auth-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,.4);
        }

        .brand-icon {
            font-size: 2.5rem;
            color: #3b82f6;
        }

        .btn-primary {
            background: #3b82f6;
            border-color: #3b82f6;
        }

            .btn-primary:hover {
                background: #2563eb;
                border-color: #2563eb;
            }

        .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 .2rem rgba(59,130,246,.25);
        }

        #preloader {
            position: fixed;
            inset: 0;
            background: #0f172a;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .spinner-ring {
            width: 44px;
            height: 44px;
            border: 5px solid #334155;
            border-top-color: #3b82f6;
            border-radius: 50%;
            animation: spin .8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center py-5">

    <div id="preloader"><div class="spinner-ring"></div></div>

    <div class="container" style="max-width:480px;">
        <div class="text-center mb-4">
            <div class="brand-icon"><i class="bi bi-headset"></i></div>
            <h4 class="text-white fw-bold mt-2">Helpdesk System</h4>
            <p class="text-secondary small">Create your account</p>
        </div>

        <div class="card auth-card">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">New Account</h5>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <form asp-action="Register" asp-controller="Account" method="post" id="registerForm">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold small">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="FullName" class="form-control" placeholder="John Smith" autocomplete="name" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <!-- Email — strict regex enforced both server-side (DataAnnotations) and client-side (pattern attr) -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold small">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            @* <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email"
                                   pattern="^[a-zA-Z0-9._%+\-]+@@(gmail|yahoo|outlook|hotmail|company)\.com$"
                                   title="Must be a valid .com email (e.g. name@gmail.com)" /> *@
                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="you@example.com"
                                   autocomplete="email"
                                   pattern="^[a-zA-Z0-9._%+\-]+@@(gmail\.com|metasyssoftware\.com|ksil\.org\.in|maildrop\.cc)$"
                                   title="Must be a valid email from an approved domain" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-1">
                        <label asp-for="Password" class="form-label fw-semibold small">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="Min. 6 characters"
                                   autocomplete="new-password" id="pwdInput" />
                            <button type="button" class="btn btn-outline-secondary" id="togglePwd" tabindex="-1">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <!-- Password strength bar -->
                    <div class="mb-3">
                        <div class="rounded mt-1" style="height:4px;background:#e2e8f0;">
                            <div id="strengthBar" class="rounded" style="width:0%;height:4px;transition:all .3s;"></div>
                        </div>
                        <div id="strengthLabel" class="small mt-1"></div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold small">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Re-enter password"
                                   autocomplete="new-password" id="confirmPwdInput" />
                            <button type="button" class="btn btn-outline-secondary" id="toggleConfirmPwd" tabindex="-1">
                                <i class="bi bi-eye" id="eyeIconConfirm"></i>
                            </button>
                        </div>
                        @* <span asp-validation-for="ConfirmPassword" class="text-danger small"></span> *@
                        <!-- Live match indicator -->
                        <div id="matchIndicator" class="small mt-1"></div>
                    </div>

                    @* <div class="mb-4">
                        <label asp-for="RoleId" class="form-label fw-semibold small">Register As</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield-check"></i></span>
                            <select asp-for="RoleId" class="form-select">
                                <option value="">— Select Role —</option>
                                <option value="2">Developer</option>
                                <option value="3">End User</option>
                            </select>
                        </div>
                        <span asp-validation-for="RoleId" class="text-danger small"></span>
                        <div class="form-text small text-muted mt-1">
                            <i class="bi bi-info-circle me-1"></i>Admin accounts are created by system administrators only.
                        </div>
                    </div> *@

                    <button type="submit" class="btn btn-primary w-100 fw-semibold" id="registerBtn">
                        <span id="regSpinner" class="spinner-border spinner-border-sm me-2 d-none"></span>
                        Create Account
                    </button>
                </form>

                <hr class="my-4" />
                <p class="text-center small text-muted mb-0">
                    Already have an account?
                    <a asp-action="Login" asp-controller="Account" class="text-primary fw-semibold">Sign in</a>
                </p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        window.addEventListener('load', () => document.getElementById('preloader').style.display = 'none');
        //submit spinner
        document.getElementById('registerForm').addEventListener('submit', function () {
            if ($(this).valid()) {
                document.getElementById('registerBtn').disabled = true;
                document.getElementById('regSpinner').classList.remove('d-none');
            }
        });
        // Toggle password visibility
        document.getElementById('togglePwd').addEventListener('click', function () {
            const inp  = document.getElementById('pwdInput');
            const icon = document.getElementById('eyeIcon');
            const show = inp.type === 'password';
            inp.type       = show ? 'text' : 'password';
            icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
        });
            // Toggle confirm password visibility
        document.getElementById('toggleConfirmPwd').addEventListener('click', function () {
            const inp  = document.getElementById('confirmPwdInput');
            const icon = document.getElementById('eyeIconConfirm');
            const show = inp.type === 'password';
            inp.type       = show ? 'text' : 'password';
            icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
        });
        // Password strength bar
        document.getElementById('pwdInput').addEventListener('input', function () {
            const val = this.value;
            const bar = document.getElementById('strengthBar');
            const lbl = document.getElementById('strengthLabel');
            let score = 0;
            if (val.length >= 6)           score++;
            if (val.length >= 10)          score++;
            if (/[A-Z]/.test(val))         score++;
            if (/[0-9]/.test(val))         score++;
            if (/[^A-Za-z0-9]/.test(val))  score++;
            const map = [
                { w:'0%',   c:'',        t:'' },
                { w:'25%',  c:'#dc3545', t:'<span class="text-danger">Weak</span>' },
                { w:'50%',  c:'#fd7e14', t:'<span class="text-warning">Fair</span>' },
                { w:'75%',  c:'#ffc107', t:'<span style="color:#856404">Good</span>' },
                { w:'100%', c:'#198754', t:'<span class="text-success">Strong</span>' },
            ];
            const m = map[Math.min(score, 4)];
            bar.style.width      = m.w;
            bar.style.background = m.c;
            lbl.innerHTML        = val.length ? m.t : '';

            // Re-trigger confirm match check whenever password changes
        checkMatch();
        });
            // Live confirm password match indicator
        document.getElementById('confirmPwdInput').addEventListener('input', checkMatch);

        function checkMatch() {
            const pwd     = document.getElementById('pwdInput').value;
            const confirm = document.getElementById('confirmPwdInput').value;
            const ind     = document.getElementById('matchIndicator');

            if (!confirm.length) { ind.innerHTML = ''; return; }

            if (pwd === confirm) {
                ind.innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>Passwords match</span>';
            } else {
                ind.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle me-1"></i>Passwords do not match</span>';
            }
        }
    </script>
</body>
</html>