@model HelpdeskTicket.Web.ViewModels.Category.CategoryViewModel
@{
    ViewData["Title"] = "Category Management";
    ViewData["ActivePage"] = "Categories";
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h5 class="fw-bold mb-0">Category Management</h5>
        <p class="text-muted small mb-0">
            @Model.Categories.Count categor@(Model.Categories.Count != 1 ? "ies" : "y") —
            @Model.Categories.Count(c => c.IsActive) active
        </p>
    </div>
</div>

<div class="row g-4">

    <!-- Left: Add / Edit form -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-semibold mb-0">
                    @if (Model.IsEdit)
                    {
                        <i class="bi bi-pencil me-2 text-warning"></i>
                        @($"Edit — {Model.Name}")
                    }
                    else
                    {
                        <i class="bi bi-plus-circle me-2 text-primary"></i>
                        @("Add New Category")
                    }
                </h6>
            </div>
            <div class="card-body">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <form asp-controller="Category" asp-action="Save" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold small">
                            Category Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               placeholder="e.g. Network Issue" maxlength="100" />
                        <div class="d-flex justify-content-end">
                            <span id="nameCount" class="text-muted small">0 / 100</span>
                        </div>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" role="switch" />
                        <label asp-for="IsActive" class="form-check-label small">
                            Active (visible in ticket form)
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        @if (Model.IsEdit)
                        {
                            <a asp-controller="Category" asp-action="Index"
                               class="btn btn-outline-secondary btn-sm flex-grow-1">
                                <i class="bi bi-x me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-warning btn-sm flex-grow-1 fw-semibold">
                                <i class="bi bi-check2 me-1"></i>Save Changes
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-primary btn-sm w-100 fw-semibold">
                                <i class="bi bi-plus-circle me-1"></i>Add Category
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Right: Categories grid -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-semibold mb-0">
                    <i class="bi bi-tags me-2 text-secondary"></i>All Categories
                </h6>
            </div>
            <div class="card-body p-0">
                @if (!Model.Categories.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-tags fs-1 opacity-25 d-block mb-2"></i>
                        No categories yet. Add the first one.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">#</th>
                                    <th>Name</th>
                                    <th>Status</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            @{
                                int srNo = 1;
                            }

                            <tbody>
                                @foreach (var cat in Model.Categories)
                                {
                                    bool isEditing = Model.Id == cat.Id;

                                    <tr class="@(isEditing ? "table-warning" : "")">
                                        <td class="ps-3 text-muted small">@srNo</td>

                                        <td class="fw-semibold small">@cat.Name</td>

                                        <td>
                                            @if (cat.IsActive)
                                            {
                                                <span class="badge bg-success rounded-pill">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-dark rounded-pill border">Inactive</span>
                                            }
                                        </td>

                                        <td class="text-center">
                                            <a asp-controller="Category" asp-action="Index"
                                               asp-route-editId="@cat.Id"
                                               class="btn btn-sm btn-outline-warning py-0 px-2"
                                               title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </td>
                                    </tr>

                                    srNo++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const nameInput = document.getElementById('Name');
        const nameCount = document.getElementById('nameCount');
        if (nameInput && nameCount) {
            function updateCount() {
                nameCount.textContent = `${nameInput.value.length} / 100`;
            }
            nameInput.addEventListener('input', updateCount);
            updateCount();
        }
    </script>
}