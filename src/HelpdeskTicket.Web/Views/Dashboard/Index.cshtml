@model HelpdeskTicket.Application.DTOs.Dashboard.DashboardStatsDto
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";

    var roleId = HelpdeskTicket.Web.Helpers.SessionHelper.GetRoleId(Context.Session);
    var fullName = HelpdeskTicket.Web.Helpers.SessionHelper.GetFullName(Context.Session);
    var roleName = HelpdeskTicket.Web.Helpers.SessionHelper.GetRoleName(Context.Session);

    // Determine if the user arrived here immediately after registration
    bool isNewUser = TempData["IsNewUser"] is bool b && b;

    string StatusBadge(string status) => status switch
    {
        // "Open" => "bg-primary",
        // "Assigned" => "bg-info text-dark",
        // "In Progress" => "bg-warning text-dark",
        // "Pending" => "bg-secondary",
        // "Waiting for User" => "bg-secondary",
        // "Resolved" => "bg-success",
        // "Closed" => "bg-dark",
        // "Reopened" => "bg-purple",
        // "Cancelled" => "bg-danger",
        // _ => "bg-secondary"
        "Open" => "bg-primary",
        "Assigned" => "bg-info text-dark",
        "In Progress" => "bg-warning text-dark",
        "Closed" => "bg-dark",
        "Resolved" => "bg-success",
        _ => "bg-secondary"
    };

    string PriorityBadge(string priority) => priority switch
    {
        "Critical" => "bg-danger",
        "High" => "bg-warning text-dark",
        "Medium" => "bg-info text-dark",
        "Low" => "bg-secondary",
        _ => "bg-secondary"
    };

    // Serialise chart data — passed to Chart.js via Html.Raw
    var statusLabels = System.Text.Json.JsonSerializer.Serialize(Model.StatusChartData.Select(x => x.Label));
    var statusCounts = System.Text.Json.JsonSerializer.Serialize(Model.StatusChartData.Select(x => x.Count));
    var priorityLabels = System.Text.Json.JsonSerializer.Serialize(Model.PriorityChartData.Select(x => x.Label));
    var priorityCounts = System.Text.Json.JsonSerializer.Serialize(Model.PriorityChartData.Select(x => x.Count));
}

<!-- Welcome header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        @* <h4 class="fw-bold mb-1">Welcome back, @fullName 👋</h4> *@
        @if (isNewUser)
        {
            <h4 class="fw-bold mb-1">Welcome, @fullName 👋</h4>
        }
        else
        {
            <h4 class="fw-bold mb-1">Welcome back, @fullName 👋</h4>
        }
        <p class="text-muted mb-0 small">
            @if (roleId == 1)
            {
                <span>You're viewing the <strong>Admin</strong> dashboard — all tickets across all users.</span>
            }
            else if (roleId == 2)
            {

                <span>You're viewing your <strong>assigned tickets</strong> as a Developer.</span>
            }
            else
            {

                <span>You're viewing <strong>your tickets</strong>.</span>
            }
        </p>
    </div>
    @* <span class="badge rounded-pill bg-primary px-3 py-2">@roleName</span> *@
</div>

<!-- ── Stat cards ─────────────────────────────────────────────── -->
<div class="row g-3 mb-4">

    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-primary">@Model.TotalTickets</div>
                <div class="text-muted small mt-1">
                    <i class="bi bi-ticket-detailed me-1"></i>Total
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-success">@Model.OpenTickets</div>
                <div class="text-muted small mt-1">
                    <i class="bi bi-folder2-open me-1"></i>Open
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold" style="color:#6f42c1;">@Model.AssignedTickets</div>
                <div class="text-muted small mt-1">
                    <i class="bi bi-person-check me-1"></i>Assigned
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-warning">@Model.InProgressTickets</div>
                <div class="text-muted small mt-1">
                    <i class="bi bi-arrow-repeat me-1"></i>In Progress
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-info">@Model.ResolvedTickets</div>
                <div class="text-muted small mt-1">
                    <i class="bi bi-check2-circle me-1"></i>Resolved
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-secondary">@Model.ClosedTickets</div>
                <div class="text-muted small mt-1">
                    <i class="bi bi-archive me-1"></i>Closed
                </div>
            </div>
        </div>
    </div>

    @* <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-danger">@Model.CriticalTickets</div>
                <div class="text-muted small mt-1">
                    <i class="bi bi-exclamation-octagon me-1"></i>Critical
                </div>
            </div>
        </div>
    </div> *@

</div>

<!-- ── Charts row ─────────────────────────────────────────────── -->
<div class="row g-3 mb-4">

    <!-- Status Doughnut Chart -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-semibold mb-0">
                    <i class="bi bi-pie-chart me-2 text-primary"></i>Tickets by Status
                </h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center"
                 style="min-height:260px;">
                @if (!Model.StatusChartData.Any() || Model.StatusChartData.All(x => x.Count == 0))
                {
                    <div class="text-center text-muted">
                        <i class="bi bi-pie-chart fs-1 opacity-25 d-block mb-2"></i>
                        No ticket data yet.
                    </div>
                }
                else
                {
                    <canvas id="statusPieChart" style="max-height:240px;"></canvas>
                }
            </div>
        </div>
    </div>

    <!-- Priority Bar Chart -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-semibold mb-0">
                    <i class="bi bi-bar-chart me-2 text-warning"></i>Tickets by Priority
                </h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center"
                 style="min-height:260px;">
                @if (!Model.PriorityChartData.Any() || Model.PriorityChartData.All(x => x.Count == 0))
                {
                    <div class="text-center text-muted">
                        <i class="bi bi-bar-chart fs-1 opacity-25 d-block mb-2"></i>
                        No ticket data yet.
                    </div>
                }
                else
                {
                    <canvas id="priorityBarChart" style="max-height:240px;"></canvas>
                }
            </div>
        </div>
    </div>

</div>

<!-- ── Recent tickets grid ─────────────────────────────────────── -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 pb-0
                d-flex align-items-center justify-content-between">
        <h6 class="fw-semibold mb-0">
            <i class="bi bi-clock-history me-2 text-secondary"></i>Recent Tickets
        </h6>
        <a asp-controller="Ticket" asp-action="Index"
           class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.RecentTickets.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 opacity-25 d-block mb-2"></i>
                No tickets found.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Priority</th>
                            <th>Assigned To</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var row = 0;
                        }
                        @foreach (var ticket in Model.RecentTickets)
                        {
                            <tr>
                                @* <td class="ps-3 text-muted small">#@ticket.Id</td> *@
                                <td class="ps-3 text-muted small fw-semibold">#@(++row)</td>
                                <td>
                                    <a asp-controller="Ticket" asp-action="Details"
                                       asp-route-id="@ticket.Id"
                                       class="text-dark text-decoration-none fw-semibold">
                                        @(ticket.Title.Length > 55 ? ticket.Title[..55] + "…" : ticket.Title)
                                    </a>
                                </td>
                                <td>
                                    <span class="badge @StatusBadge(ticket.StatusName) rounded-pill">
                                        @ticket.StatusName
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @PriorityBadge(ticket.PriorityName) rounded-pill">
                                        @ticket.PriorityName
                                    </span>
                                </td>
                                <td class="small text-muted">@ticket.AssignedToName</td>
                                <td class="small text-muted">
                                    @ticket.CreatedDateTime.ToString("dd MMM yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        // ── Status Doughnut Chart ──────────────────────────────────
        const statusLabels = @Html.Raw(statusLabels);
        const statusCounts = @Html.Raw(statusCounts);
        const statusCanvas = document.getElementById('statusPieChart');

        if (statusCanvas) {
            const pieColors = [
                '#3b82f6', '#22c55e', '#f59e0b', '#6b7280',
                '#a855f7', '#14b8a6', '#1e293b', '#f97316', '#ef4444'
            ];
            new Chart(statusCanvas, {
                type: 'doughnut',
                data: {
                    labels: statusLabels,
                    datasets: [{
                        data:            statusCounts,
                        backgroundColor: pieColors.slice(0, statusLabels.length),
                        borderWidth:     2,
                        borderColor:     '#fff'
                    }]
                },
                options: {
                    responsive:          true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: { font: { size: 11 }, boxWidth: 12, padding: 10 }
                        },
                        tooltip: {
                            callbacks: {
                                label: ctx =>
                                    ` ${ctx.label}: ${ctx.raw} ticket${ctx.raw !== 1 ? 's' : ''}`
                            }
                        }
                    }
                }
            });
        }

        // ── Priority Bar Chart ─────────────────────────────────────
        const priorityLabels = @Html.Raw(priorityLabels);
        const priorityCounts = @Html.Raw(priorityCounts);
        const barCanvas      = document.getElementById('priorityBarChart');

        if (barCanvas) {
            const barColors = ['#6b7280', '#3b82f6', '#f59e0b', '#ef4444'];
            new Chart(barCanvas, {
                type: 'bar',
                data: {
                    labels: priorityLabels,
                    datasets: [{
                        label:           'Tickets',
                        data:            priorityCounts,
                        backgroundColor: barColors.slice(0, priorityLabels.length),
                        borderRadius:    6,
                        borderSkipped:   false
                    }]
                },
                options: {
                    responsive:          true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: ctx =>
                                    ` ${ctx.raw} ticket${ctx.raw !== 1 ? 's' : ''}`
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { stepSize: 1, precision: 0 },
                            grid:  { color: '#f1f5f9' }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });
        }
    </script>
}